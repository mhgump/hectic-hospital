{
  "name": "jamkit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview --host",
    "e2e": "npm run build && npx playwright test",
    "e2e:fast": "npx playwright test",
    "e2e:headed": "npx playwright test --headed",
    "e2e:report": "npx playwright show-report",
    "kenney:search": "node scripts/kenneySearch.mjs",
    "kenney:catalog": "node scripts/kenneyCatalog.mjs"
  },
  "dependencies": {
    "@babylonjs/core": "^8.44.1",
    "@babylonjs/havok": "^1.3.10",
    "@babylonjs/loaders": "^8.44.1"
  },
  "devDependencies": {
    "@babylonjs/inspector": "^8.44.1",
    "@playwright/test": "^1.55.0",
    "playwright": "^1.57.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
